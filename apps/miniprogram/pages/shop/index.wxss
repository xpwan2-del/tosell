.page {
  padding: 24rpx;
}
.shop-head,
.product {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.shop-head {
  border-top: 8rpx solid #1677ff;
}
.shop-name,
.title {
  display: block;
  font-weight: 600;
}
.shop-desc {
  display: block;
  color: #65737d;
  margin: 12rpx 0;
}
.price {
  display: block;
  color: #0a6b5f;
  margin-top: 8rpx;
}
.status,
.meta,
.hint {
  display: block;
  color: #65737d;
  margin-top: 8rpx;
}
.actions {
  margin-top: 16rpx;
}
.service {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #65737d;
}
.service-qr {
  width: 148rpx;
  height: 148rpx;
  border-radius: 8rpx;
  background: #eef3f6;
}
.error {
  color: #a32626;
  background: #fff0f0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
