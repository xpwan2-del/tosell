.page {
  padding: 24rpx;
}
.card {
  display: grid;
  gap: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
}
.title {
  font-size: 34rpx;
  font-weight: 700;
}
.row {
  display: grid;
  gap: 8rpx;
  border-top: 1rpx solid #e8edf0;
  padding-top: 14rpx;
}
.hint {
  color: #65737d;
}
.error {
  color: #a32626;
  background: #fff0f0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
