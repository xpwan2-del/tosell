.page {
  padding: 24rpx;
}
.card {
  display: grid;
  gap: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
}
input {
  border: 1rpx solid #ccd6dc;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  height: 56rpx;
  box-sizing: border-box;
}
.hint {
  color: #65737d;
  margin-bottom: 16rpx;
}
.error {
  color: #a32626;
  background: #fff0f0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
