<view class="page">
  <view class="card">
    <text>订单号：{{order.orderNo}}</text>
    <text>状态：{{order.status}}</text>
    <text>履约：{{order.fulfillmentStatus}}</text>
    <text>售后：{{order.refundStatus}}</text>
    <text>权益：{{order.entitlement}}</text>
    <button bindtap="requestRefund">申请售后</button>
  </view>
</view>
