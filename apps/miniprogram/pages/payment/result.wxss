.page {
  padding: 24rpx;
}
.card {
  display: grid;
  gap: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
}
.title {
  font-size: 34rpx;
  font-weight: 700;
}
.actions {
  display: flex;
  gap: 12rpx;
}
.hint {
  color: #65737d;
  margin-bottom: 16rpx;
}
.error {
  color: #a32626;
  background: #fff0f0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
