<view class="page">
  <view wx:if="{{error}}" class="error">{{error}}</view>
  <view wx:if="{{loading}}" class="hint">加载中...</view>

  <view class="card">
    <text class="title">代理中心</text>
    <view class="stats">
      <text>GMV：¥{{dashboard.gmv}}</text>
      <text>预估收益：¥{{dashboard.expectedIncome}}</text>
      <text>退款率：{{dashboard.refundRate}}</text>
      <text>活跃商品：{{dashboard.activeProductCount}}</text>
    </view>
    <text>店铺：{{shop.name}}</text>
    <text>店铺状态：{{shop.status}}</text>
    <text>客服微信：{{shop.customerServiceWechat}}</text>
    <image wx:if="{{shop.customerServiceQrUrl}}" class="service-qr" src="{{shop.customerServiceQrUrl}}" mode="aspectFill" />
    <input placeholder="联系人手机号" value="{{contactPhone}}" bindinput="onContactPhoneInput" />
    <input placeholder="客服微信" value="{{customerServiceWechat}}" bindinput="onCustomerServiceInput" />
    <input placeholder="客服二维码图片地址" value="{{customerServiceQrUrl}}" bindinput="onCustomerServiceQrInput" />
    <input placeholder="店铺名称" value="{{shopName}}" bindinput="onShopNameInput" />
    <input placeholder="店铺公告" value="{{announcement}}" bindinput="onAnnouncementInput" />
    <view class="actions">
      <button bindtap="submitApplication">提交入驻资料</button>
      <button bindtap="saveShop">保存店铺资料</button>
    </view>
  </view>

  <view class="card">
    <text class="title">店铺装修</text>
    <input placeholder="主题色，例如 #00aa88" value="{{themeColor}}" bindinput="onThemeColorInput" />
    <input placeholder="分享标题" value="{{shareTitle}}" bindinput="onShareTitleInput" />
    <input placeholder="头图地址" value="{{bannerUrl}}" bindinput="onBannerUrlInput" />
    <button bindtap="saveDecor">保存装修</button>
  </view>

  <view class="card">
    <text class="title">平台商品选品</text>
    <block wx:for="{{platformProducts}}" wx:key="id">
      <view class="row">
        <text>{{item.name}}</text>
        <text>供货价 ¥{{item.supplyPrice}} / 最低价 ¥{{item.minSalePrice}} / 建议价 ¥{{item.suggestedSalePrice}}</text>
      </view>
    </block>
    <view class="price-row">
      <input placeholder="平台商品 ID" value="{{selectedPlatformProductId}}" bindinput="onPlatformProductInput" />
      <input placeholder="店铺商品 ID" value="{{selectedAgentProductId}}" bindinput="onAgentProductInput" />
      <input placeholder="售价，单位分" value="{{priceCents}}" bindinput="onPriceInput" />
      <button bindtap="selectPlatformProduct">选品上架</button>
      <button bindtap="updatePrice">保存售价</button>
      <button bindtap="batchSelectProducts">批量选品</button>
    </view>
    <block wx:for="{{agentProducts}}" wx:key="id">
      <view class="row">
        <text>{{item.id}} / {{item.productName}}</text>
        <text>售价 ¥{{item.salePrice}} / 供货价 ¥{{item.supplyPrice}} / 最低价 ¥{{item.minSalePrice}}</text>
      </view>
    </block>
  </view>

  <view class="card">
    <text class="title">自有商品提交</text>
    <input placeholder="商品名称" value="{{ownProductName}}" bindinput="onOwnProductNameInput" />
    <input placeholder="售价，单位分" value="{{ownProductSalePriceCents}}" bindinput="onOwnProductSalePriceInput" />
    <input placeholder="最低售价，单位分" value="{{ownProductMinPriceCents}}" bindinput="onOwnProductMinPriceInput" />
    <button bindtap="submitOwnProduct">提交审核</button>
  </view>

  <view class="card">
    <text class="title">订单收益</text>
    <block wx:for="{{orders}}" wx:key="orderNo">
      <view class="row">
        <text>{{item.orderNo}}：{{item.status}} / {{item.settlementStatus}}</text>
        <text>实付 ¥{{item.paidAmount}}，预估收益 ¥{{item.expectedIncome}}</text>
      </view>
    </block>
  </view>

  <view class="card">
    <text class="title">结算记录</text>
    <block wx:for="{{settlements}}" wx:key="settlementNo">
      <text>{{item.settlementNo}}：{{item.status}}</text>
    </block>
    <text wx:if="{{settlements.length === 0}}">暂无结算单</text>
  </view>

  <view class="card">
    <text class="title">追扣记录</text>
    <block wx:for="{{clawbacks}}" wx:key="clawbackNo">
      <text>{{item.clawbackNo}}：{{item.status}}</text>
    </block>
    <text wx:if="{{clawbacks.length === 0}}">暂无追扣</text>
  </view>

  <view class="card">
    <text class="title">消息通知</text>
    <block wx:for="{{notifications}}" wx:key="id">
      <view class="row">
        <text>{{item.title}}</text>
        <text>{{item.content}}</text>
      </view>
    </block>
    <text wx:if="{{notifications.length === 0}}">暂无消息</text>
  </view>
</view>
