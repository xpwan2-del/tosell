# Production-test database policy:
# Use the Google VM PostgreSQL database through the documented SSH tunnel.
# Replace <password> with the real database password before running API/browser tests.
DATABASE_URL="postgresql://tosell:<password>@127.0.0.1:15432/tosell?sslmode=require"
APP_ENV="production"
ALLOW_DEMO_AUTH="false"
AUTH_TOKEN_SECRET=""
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_PAY_API_KEY=""
WECHAT_PAY_CERT_SERIAL_NO=""
WECHAT_PAY_PRIVATE_KEY_PATH=""
WECHAT_PAY_PLATFORM_CERT_PATH=""
WECHAT_PAY_NOTIFY_URL=""
WECHAT_REFUND_NOTIFY_URL=""
MOCK_PAYMENT_ENABLED="false"
