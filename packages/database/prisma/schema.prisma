model ChannelProductOffer {
  id                         String             @id @default(cuid())
  channelRelationId          String             @map("channel_relation_id")
  platformProductId          String             @map("platform_product_id")
  resellSupplyPriceCents     BigInt             @map("resell_supply_price_cents")
  firstTierSupplyPriceCents  BigInt?            @map("first_tier_supply_price_cents")
  secondTierSupplyPriceCents BigInt?            @map("second_tier_supply_price_cents")
  terminalMinSalePriceCents  BigInt?            @map("terminal_min_sale_price_cents")
  status                     AgentProductStatus @default(listed)
  listedAt                   DateTime?          @map("listed_at")
  delistedAt                 DateTime?          @map("delisted_at")
  idempotencyKey             String             @unique @map("idempotency_key")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  relation        ChannelRelation @relation(fields: [channelRelationId], references: [id])
  platformProduct PlatformProduct @relation(fields: [platformProductId], references: [id])

  @@unique([channelRelationId, platformProductId])
  @@index([platformProductId, status])
  @@map("channel_product_offers")
}

model PaymentChannelConfig {
  id            String         @id @default(cuid())
  channel       PaymentChannel @unique
  enabled       Boolean        @default(false)
  feeBps        Int            @default(0) @map("fee_bps")
  fixedFeeCents BigInt         @default(0) @map("fixed_fee_cents")
  configJson    Json?          @map("config_json")
  statusNote    String?        @map("status_note")
  updatedById   String?        @map("updated_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("payment_channel_configs")
}

model LedgerEntry {
  id                   String            @id @default(cuid())
  ledgerNo             String            @unique @map("ledger_no")
  agentId              String?           @map("agent_id")
  merchantId           String?           @map("merchant_id")
  shopId               String?           @map("shop_id")
  subjectType          LedgerSubjectType @map("subject_type")
  subjectId            String            @map("subject_id")
  accountType          LedgerAccountType @map("account_type")
  entryType            LedgerEntryType   @map("entry_type")
  direction            LedgerDirection
  amountCents          BigInt            @map("amount_cents")
  currency             String            @default("CNY")
  sourceType           String            @map("source_type")
  sourceId             String            @map("source_id")
  orderId              String?           @map("order_id")
  settlementId         String?           @map("settlement_id")
  clearingId           String?           @map("clearing_id")
  refundId             String?           @map("refund_id")
  clawbackId           String?           @map("clawback_id")
  depositTransactionId String?           @map("deposit_transaction_id")
  idempotencyKey       String            @unique @map("idempotency_key")
  balanceBeforeCents   BigInt?           @map("balance_before_cents")
  balanceAfterCents    BigInt?           @map("balance_after_cents")
  reversalOfLedgerId   String?           @map("reversal_of_ledger_id")
  createdAt            DateTime          @default(now()) @map("created_at")

  agent              Agent?              @relation(fields: [agentId], references: [id])
  merchant           Merchant?           @relation(fields: [merchantId], references: [id])
  shop               Shop?               @relation(fields: [shopId], references: [id])
  order              Order?              @relation(fields: [orderId], references: [id])
  settlement         SettlementSheet?    @relation(fields: [settlementId], references: [id])
  clearing           ClearingRecord?     @relation(fields: [clearingId], references: [id])
  refund             Refund?             @relation(fields: [refundId], references: [id])
  clawback           Clawback?           @relation(fields: [clawbackId], references: [id])
  depositTransaction DepositTransaction? @relation(fields: [depositTransactionId], references: [id])

  @@index([agentId, createdAt])
  @@index([merchantId, createdAt])
  @@index([sourceType, sourceId])
  @@index([orderId])
  @@index([clearingId])
  @@map("ledger_entries")
}

model LedgerAccount {
  id           String            @id @default(cuid())
  subjectType  LedgerSubjectType @map("subject_type")
  subjectId    String            @map("subject_id")
  accountType  LedgerAccountType @map("account_type")
  balanceCents BigInt            @default(0) @map("balance_cents")
  version      Int               @default(0)
  updatedAt    DateTime          @updatedAt @map("updated_at")
  createdAt    DateTime          @default(now()) @map("created_at")

  @@unique([subjectType, subjectId, accountType])
  @@map("ledger_accounts")
}

model RiskFreeze {
  id              String           @id @default(cuid())
  targetType      String           @map("target_type")
  targetId        String           @map("target_id")
  agentId         String?          @map("agent_id")
  freezeType      String           @map("freeze_type")
  status          RiskFreezeStatus @default(active)
  reasonCode      String           @map("reason_code")
  reasonText      String           @map("reason_text")
  activeUniqueKey String?          @unique @map("active_unique_key")
  createdById     String?          @map("created_by")
  releasedById    String?          @map("released_by")
  releasedAt      DateTime?        @map("released_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([agentId, status])
  @@index([targetType, targetId, freezeType, status])
  @@map("risk_freezes")
}

model Complaint {
  id             String          @id @default(cuid())
  orderId        String          @map("order_id")
  agentId        String          @map("agent_id")
  userId         String          @map("user_id")
  status         ComplaintStatus @default(pending)
  complaintType  String          @map("complaint_type")
  responsibility Responsibility  @default(undecided)
  resolutionJson Json?           @map("resolution_json")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([agentId, status])
  @@index([orderId])
  @@map("complaints")
}

model AuditLog {
  id             String    @id @default(cuid())
  actorType      ActorType @map("actor_type")
  actorId        String    @map("actor_id")
  action         String
  targetType     String    @map("target_type")
  targetId       String    @map("target_id")
  beforeJson     Json?     @map("before_json")
  afterJson      Json?     @map("after_json")
  reason         String?
  idempotencyKey String    @unique @map("idempotency_key")
  requestId      String    @map("request_id")
  ip             String?
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([actorType, actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([requestId])
  @@map("audit_logs")
}

model AdminUser {
  id           String     @id @default(cuid())
  username     String     @unique
  displayName  String     @map("display_name")
  passwordHash String     @map("password_hash")
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  roles                      AdminUserRole[]
  createdMerchantAccounts    MerchantAccount[]          @relation("MerchantAccountCreatedBy")
  createdMerchants           Merchant[]                 @relation("MerchantCreatedBy")
  createdMerchantInviteCodes MerchantInviteCode[]       @relation("MerchantInviteCodeCreatedBy")
  createdShops               Shop[]                     @relation("ShopCreatedBy")
  createdCollectionChannels  ShopCollectionChannel[]    @relation("ShopCollectionChannelCreatedBy")
  clearingConfirmations      ClearingConfirmation[]     @relation("ClearingConfirmationConfirmedBy")
  createdCouponTemplates     CouponTemplate[]           @relation("CouponTemplateCreatedBy")
  refundManualConfirmations  RefundManualConfirmation[] @relation("RefundManualConfirmationConfirmedBy")
  sessions                   AuthSession[]

  @@map("admin_users")
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       AdminUserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@map("permissions")
}

model AdminUserRole {
  adminUserId String   @map("admin_user_id")
  roleId      String   @map("role_id")
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  role      Role      @relation(fields: [roleId], references: [id])

  @@id([adminUserId, roleId])
  @@map("admin_user_roles")
}

model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}
