  issuedOrderId       String?           @map("issued_order_id")
  issuedOrderItemId   String?           @map("issued_order_item_id")
  issuedAt            DateTime?         @map("issued_at")
  lockIdempotencyKey  String?           @unique @map("lock_idempotency_key")
  issueIdempotencyKey String?           @unique @map("issue_idempotency_key")
