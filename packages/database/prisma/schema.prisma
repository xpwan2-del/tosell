generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
}

enum AgentStatus {
  draft
  pending_review
  rejected
  pending_deposit
  active
  frozen
  disabled
  exit_observation
  exited
}

enum DepositStatus {
  pending_payment
  paid
  partially_deducted
  frozen
  refund_reviewing
  refunded
  insufficient
}

enum ShopStatus {
  not_opened
  configuring
  open
  frozen
  disabled
}

enum ReviewStatus {
  draft
  pending_review
  rejected
  approved
}

enum ProductStatus {
  draft
  active
  inactive
  risk_removed
}

enum AgentProductStatus {
  draft
  pending_review
  rejected
  approved
  listed
  delisted
  risk_removed
}

enum ProductType {
  platform
  agent_owned
}

enum FulfillmentType {
  manual
  automatic
  external
}

enum OrderStatus {
  pending_payment
  paid
  fulfilling
  fulfilled
  fulfillment_failed
  after_sale_pending
  refunding
  refunded
  closed
}

enum PaymentStatus {
  unpaid
  paying
  paid
  failed
  cancelled
  expired
}

enum PaymentConfirmationStatus {
  pending
  confirmed
  rejected
}

enum FulfillmentStatus {
  not_started
  processing
  success
  failed
  resent
  revoked
}

enum RightsCodeStatus {
  available
  issued
  voided
}

enum RefundStatus {
  none
  pending
  refunding
  refunded
  rejected
  cancelled
}

enum SettlementStatus {
  pending
  frozen
  settleable
  settling
  settled
  clawback_pending
  clawed_back
}

enum RiskStatus {
  normal
  order_frozen
  shop_frozen
  settlement_restricted
  product_removed
  disabled
}

enum CallbackProcessStatus {
  received
  processed
  ignored_duplicate
  failed
}

enum AfterSaleStatus {
  pending
  agent_processing
  platform_intervening
  refund_approved
  refunding
  refunded
  rejected
  cancelled
}

enum Responsibility {
  platform
  agent
  first_tier
  second_tier
  third_tier
  user
  mixed
  undecided
}

enum ShopOwnerType {
  platform
  agent
}

enum SalesChannelType {
  platform_self_operated
  single_agent
  two_tier
  three_tier
}

enum UserIdentityType {
  wechat_miniprogram
  h5_phone
  h5_guest
  admin_mock
}

enum MerchantTier {
  first_tier
  second_tier
  third_tier
}

enum MerchantCreationSource {
  admin_manual
  invite_application
  self_application
  migration
}

enum MerchantAccountRole {
  owner
  operator
}

enum MerchantAccountStatus {
  pending_delivery
  active
  disabled
}

enum AuthSubjectType {
  admin
  merchant
  agent
  user
}

enum AuthSessionStatus {
  active
  revoked
  expired
}

enum InitialAccountDeliveryStatus {
  pending
  delivered
  acknowledged
}

enum ChannelRelationType {
  two_tier
  three_tier
}

enum SaleSourceType {
  agent_product
  merchant_product
  platform_shop_product
}

enum CollectionChannelType {
  wechat_qr
  alipay_qr
  bank_transfer
  other
}

enum CollectionChannelStatus {
  pending_review
  active
  disabled
  rejected
}

enum VirtualCodeStatus {
  available
  reserved
  issued
  voided
  refunded
  locked
}

enum ExtractSecretStatus {
  active
  locked
  revoked
  expired
}

enum ExtractLogResult {
  success
  failed
  locked
  revoked
  expired
}

enum ClearingRecordStatus {
  draft
  confirmed
  cancelled
}

enum ClearingItemType {
  supply_payable
  service_fee
  clawback
  refund_adjustment
  coupon_subsidy
}

enum ClearingConfirmationStatus {
  pending
  confirmed
  rejected
}

enum CouponTemplateStatus {
  draft
  active
  inactive
  voided
}

enum CouponStatus {
  active
  used
  expired
  voided
}

enum CouponDiscountType {
  fixed_amount
}

enum CouponScopeType {
  all_products
  platform_product
  merchant_product
  shop
}

enum ChannelStatus {
  pending_review
  active
  frozen
  closed
  rejected
}

enum PaymentChannel {
  wechat_miniprogram
  wechat_h5_jsapi
  wechat_h5
  alipay_wap
  mock
}

enum SettlementRole {
  single_agent
  first_tier
  second_tier
  third_tier
}

enum ServiceFeeBearer {
  platform
  agent
  user
  mixed
  none
}

enum SettlementSheetStatus {
  draft
  confirmed
  payout_pending
  paid
  cancelled
}

enum ManualPayoutStatus {
  pending
  paid
  failed
  cancelled
}

enum DepositTransactionType {
  pay
  freeze
  unfreeze
  deduct
  refund
  adjustment
}

enum ClawbackStatus {
  pending
  deducting
  completed
  insufficient
  cancelled
}

enum ClawbackDeductFrom {
  pending_income
  payable_income
  deposit
  mixed
}

enum LedgerDirection {
  debit
  credit
}

enum LedgerSubjectType {
  agent
  platform
  user
}

enum LedgerAccountType {
  agent_pending_income
  agent_frozen_income
  agent_payable_income
  agent_paid_income
  agent_clawback_receivable
  agent_deposit_available
  agent_deposit_frozen
  platform_service_fee_income
  platform_refund_cost
  platform_self_operated_revenue
  platform_self_operated_fulfillment_cost
  platform_payment_channel_fee
  platform_self_operated_refund_cost
  first_tier_pending_income
  first_tier_payable_income
  second_tier_pending_income
  second_tier_payable_income
  third_tier_pending_income
  third_tier_payable_income
}

enum LedgerEntryType {
  ORDER_AGENT_INCOME_PENDING
  ORDER_SERVICE_FEE_ACCRUAL
  ORDER_PLATFORM_SELF_REVENUE
  ORDER_PLATFORM_SELF_COST
  ORDER_PAYMENT_CHANNEL_FEE
  ORDER_FIRST_TIER_INCOME_PENDING
  ORDER_SECOND_TIER_INCOME_PENDING
  ORDER_THIRD_TIER_INCOME_PENDING
  REFUND_AGENT_BEAR
  REFUND_PLATFORM_BEAR
  REFUND_FIRST_TIER_BEAR
  REFUND_SECOND_TIER_BEAR
  REFUND_THIRD_TIER_BEAR
  SERVICE_FEE_REFUND
  SETTLEMENT_LOCK
  SETTLEMENT_PAYOUT
  CLAWBACK_CREATE
  CLAWBACK_DEDUCT_PENDING
  CLAWBACK_DEDUCT_PAYOUT
  CLAWBACK_DEDUCT_DEPOSIT
  DEPOSIT_PAY
  DEPOSIT_DEDUCT
  DEPOSIT_REFUND
  RISK_FREEZE
  RISK_UNFREEZE
  MANUAL_ADJUST
}

enum RiskFreezeStatus {
  active
  released
  cancelled
}

enum ComplaintStatus {
  pending
  processing
  resolved
  rejected
  cancelled
}

enum ActorType {
  user
  agent
  merchant
  admin
  system
}

enum CodePlaintextAccessType {
  view
  export
}

model User {
  id        String     @id @default(cuid())
  openid    String?    @unique
  unionid   String?    @unique
  phone     String?
  status    UserStatus @default(active)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  agent                Agent?
  applications         AgentApplication[]
  identities           UserIdentity[]
  sessions             AuthSession[]
  orders               Order[]
  entitlements         Entitlement[]
  merchantAccounts     MerchantAccount[]
  merchantApplications MerchantApplication[]
  userCoupons          UserCoupon[]

  @@map("users")
}

model UserIdentity {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  identityType UserIdentityType @map("identity_type")
  provider     String
  externalId   String           @map("external_id")
  verifiedAt   DateTime?        @map("verified_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([identityType, provider, externalId])
  @@index([userId, identityType])
  @@map("user_identities")
}

model AuthSession {
  id                String            @id @default(cuid())
  sessionNo         String            @unique @map("session_no")
  subjectType       AuthSubjectType   @map("subject_type")
  userId            String?           @map("user_id")
  adminUserId       String?           @map("admin_user_id")
  merchantAccountId String?           @map("merchant_account_id")
  merchantId        String?           @map("merchant_id")
  agentId           String?           @map("agent_id")
  tokenHash         String            @unique @map("token_hash")
  refreshTokenHash  String?           @unique @map("refresh_token_hash")
  status            AuthSessionStatus @default(active)
  issuedAt          DateTime          @default(now()) @map("issued_at")
  expiresAt         DateTime          @map("expires_at")
  revokedAt         DateTime?         @map("revoked_at")
  lastSeenAt        DateTime?         @map("last_seen_at")
  ip                String?
  userAgent         String?           @map("user_agent")
  idempotencyKey    String            @unique @map("idempotency_key")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user            User?            @relation(fields: [userId], references: [id])
  adminUser       AdminUser?       @relation(fields: [adminUserId], references: [id])
  merchantAccount MerchantAccount? @relation(fields: [merchantAccountId], references: [id])
  merchant        Merchant?        @relation(fields: [merchantId], references: [id])
  agent           Agent?           @relation(fields: [agentId], references: [id])

  @@index([subjectType, status, expiresAt])
  @@index([userId, status])
  @@index([adminUserId, status])
  @@index([merchantAccountId, status])
  @@index([merchantId, status])
  @@index([agentId, status])
  @@map("auth_sessions")
}

model Agent {
  id            String        @id @default(cuid())
  userId        String        @unique @map("user_id")
  agentNo       String        @unique @map("agent_no")
  name          String
  contactPhone  String?       @map("contact_phone")
  status        AgentStatus   @default(draft)
  riskStatus    RiskStatus    @default(normal) @map("risk_status")
  depositStatus DepositStatus @default(pending_payment) @map("deposit_status")
  approvedAt    DateTime?     @map("approved_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user                    User                   @relation(fields: [userId], references: [id])
  applications            AgentApplication[]
  shop                    Shop?
  agentProducts           AgentProduct[]
  productReviews          AgentProductReview[]
  depositAccount          DepositAccount?
  depositTransactions     DepositTransaction[]
  orders                  Order[]
  afterSales              AfterSale[]
  settlementSheets        SettlementSheet[]
  ledgerEntries           LedgerEntry[]
  notifications           AgentNotification[]
  sessions                AuthSession[]
  firstTierAuthorizations ChannelAuthorization[] @relation("FirstTierAuthorization")
  firstTierRelations      ChannelRelation[]      @relation("FirstTierRelations")
  secondTierRelations     ChannelRelation[]      @relation("SecondTierRelations")
  thirdTierRelations      ChannelRelation[]      @relation("ThirdTierRelations")

  @@index([status])
  @@index([riskStatus])
  @@map("agents")
}

model AgentApplication {
  id                    String       @id @default(cuid())
  agentId               String?      @map("agent_id")
  userId                String       @map("user_id")
  identityInfoJson      Json         @map("identity_info_json")
  contactInfoJson       Json         @map("contact_info_json")
  customerServiceWechat String       @map("customer_service_wechat")
  status                ReviewStatus @default(pending_review)
  rejectReason          String?      @map("reject_reason")
  reviewedById          String?      @map("reviewed_by")
  reviewedAt            DateTime?    @map("reviewed_at")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  agent Agent? @relation(fields: [agentId], references: [id])
  user  User   @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
  @@index([agentId])
  @@map("agent_applications")
}

model MerchantAccount {
  id                    String                       @id @default(cuid())
  userId                String?                      @map("user_id")
  merchantId            String?                      @map("merchant_id")
  username              String                       @unique
  phone                 String?
  email                 String?
  passwordHash          String?                      @map("password_hash")
  role                  MerchantAccountRole          @default(owner)
  status                MerchantAccountStatus        @default(pending_delivery)
  initialDeliveryStatus InitialAccountDeliveryStatus @default(pending) @map("initial_delivery_status")
  initialDeliveredAt    DateTime?                    @map("initial_delivered_at")
  mustChangePassword    Boolean                      @default(true) @map("must_change_password")
  passwordChangedAt     DateTime?                    @map("password_changed_at")
  createdByAdminId      String?                      @map("created_by_admin_id")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")

  user      User?         @relation(fields: [userId], references: [id])
  merchant  Merchant?     @relation(fields: [merchantId], references: [id])
  createdBy AdminUser?    @relation("MerchantAccountCreatedBy", fields: [createdByAdminId], references: [id])
  sessions  AuthSession[]

  @@index([merchantId, status])
  @@index([userId])
  @@map("merchant_accounts")
}

model Merchant {
  id                   String                       @id @default(cuid())
  merchantNo           String                       @unique @map("merchant_no")
  tier                 MerchantTier                 @default(first_tier)
  name                 String
  contactPhone         String?                      @map("contact_phone")
  status               AgentStatus                  @default(pending_deposit)
  riskStatus           RiskStatus                   @default(normal) @map("risk_status")
  depositStatus        DepositStatus                @default(pending_payment) @map("deposit_status")
  creationSource       MerchantCreationSource       @default(self_application) @map("creation_source")
  createdByAdminId     String?                      @map("created_by_admin_id")
  initialAccountStatus InitialAccountDeliveryStatus @default(pending) @map("initial_account_status")
  approvedAt           DateTime?                    @map("approved_at")
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")

  accounts            MerchantAccount[]
  applications        MerchantApplication[]
  inviteCodes         MerchantInviteCode[]
  shops               Shop[]
  products            MerchantProduct[]
  productReviews      MerchantProductReview[]
  depositAccount      DepositAccount?
  depositTransactions DepositTransaction[]
  orders              Order[]
  afterSales          AfterSale[]
  fulfillmentRecords  FulfillmentRecord[]
  clearingRecords     ClearingRecord[]
  clearingItems       ClearingItem[]
  ledgerEntries       LedgerEntry[]
  sessions            AuthSession[]
  firstTierRelations  ChannelRelation[]       @relation("FirstTierMerchantRelations")
  secondTierRelations ChannelRelation[]       @relation("SecondTierMerchantRelations")
  thirdTierRelations  ChannelRelation[]       @relation("ThirdTierMerchantRelations")
  createdBy           AdminUser?              @relation("MerchantCreatedBy", fields: [createdByAdminId], references: [id])

  @@index([tier, status])
  @@index([depositStatus])
  @@index([creationSource, createdAt])
  @@map("merchants")
}

model MerchantApplication {
  id                    String       @id @default(cuid())
  merchantId            String?      @map("merchant_id")
  userId                String?      @map("user_id")
  inviteCodeId          String?      @map("invite_code_id")
  tier                  MerchantTier @default(first_tier)
  identityInfoJson      Json         @map("identity_info_json")
  contactInfoJson       Json         @map("contact_info_json")
  customerServiceWechat String?      @map("customer_service_wechat")
  status                ReviewStatus @default(pending_review)
  rejectReason          String?      @map("reject_reason")
  reviewedById          String?      @map("reviewed_by")
  reviewedAt            DateTime?    @map("reviewed_at")
  idempotencyKey        String       @unique @map("idempotency_key")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  merchant   Merchant?           @relation(fields: [merchantId], references: [id])
  user       User?               @relation(fields: [userId], references: [id])
  inviteCode MerchantInviteCode? @relation(fields: [inviteCodeId], references: [id])

  @@index([tier, status, createdAt])
  @@index([merchantId])
  @@map("merchant_applications")
}

model MerchantInviteCode {
  id                         String       @id @default(cuid())
  codeHash                   String       @unique @map("code_hash")
  issuerMerchantId           String?      @map("issuer_merchant_id")
  tier                       MerchantTier
  maxUses                    Int          @default(1) @map("max_uses")
  usedCount                  Int          @default(0) @map("used_count")
  depositRequiredAmountCents BigInt?      @map("deposit_required_amount_cents")
  status                     ReviewStatus @default(approved)
  expiresAt                  DateTime?    @map("expires_at")
  createdByAdminId           String?      @map("created_by_admin_id")
  idempotencyKey             String       @unique @map("idempotency_key")
  createdAt                  DateTime     @default(now()) @map("created_at")
  updatedAt                  DateTime     @updatedAt @map("updated_at")

  issuer       Merchant?             @relation(fields: [issuerMerchantId], references: [id])
  createdBy    AdminUser?            @relation("MerchantInviteCodeCreatedBy", fields: [createdByAdminId], references: [id])
  applications MerchantApplication[]

  @@index([issuerMerchantId, status])
  @@index([tier, status, expiresAt])
  @@map("merchant_invite_codes")
}

model Shop {
  id                    String                  @id @default(cuid())
  ownerType             ShopOwnerType           @default(agent) @map("owner_type")
  agentId               String?                 @unique @map("agent_id")
  merchantId            String?                 @unique @map("merchant_id")
  shopNo                String                  @unique @map("shop_no")
  name                  String
  logoUrl               String?                 @map("logo_url")
  announcement          String?
  customerServiceQrUrl  String?                 @map("customer_service_qr_url")
  collectionAccountName String?                 @map("collection_account_name")
  collectionQrUrl       String?                 @map("collection_qr_url")
  collectionNote        String?                 @map("collection_note")
  themeColor            String?                 @map("theme_color")
  bannerUrl             String?                 @map("banner_url")
  shareTitle            String?                 @map("share_title")
  sharePath             String                  @unique @map("share_path")
  status                ShopStatus              @default(not_opened)
  riskStatus            RiskStatus              @default(normal) @map("risk_status")
  creationSource        MerchantCreationSource? @map("creation_source")
  createdByAdminId      String?                 @map("created_by_admin_id")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  agent                  Agent?                       @relation(fields: [agentId], references: [id])
  merchant               Merchant?                    @relation(fields: [merchantId], references: [id])
  createdBy              AdminUser?                   @relation("ShopCreatedBy", fields: [createdByAdminId], references: [id])
  customerServices       ShopCustomerServiceBinding[]
  collectionChannels     ShopCollectionChannel[]
  paymentConfirmations   PaymentConfirmation[]
  productGroups          ShopProductGroup[]
  agentProducts          AgentProduct[]
  merchantProducts       MerchantProduct[]
  merchantProductReviews MerchantProductReview[]
  productReviews         AgentProductReview[]
  platformShopProducts   PlatformShopProduct[]
  orders                 Order[]
  afterSales             AfterSale[]
  fulfillmentRecords     FulfillmentRecord[]
  clearingRecords        ClearingRecord[]
  couponScopes           CouponScope[]
  settlementItems        SettlementItem[]
  ledgerEntries          LedgerEntry[]

  @@index([status])
  @@index([ownerType, status])
  @@index([merchantId, status])
  @@map("shops")
}

model ShopProductGroup {
  id              String   @id @default(cuid())
  shopId          String   @map("shop_id")
  name            String
  sortOrder       Int      @default(0) @map("sort_order")
  agentProductIds Json     @map("agent_product_ids")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId, sortOrder])
  @@map("shop_product_groups")
}

model ShopCustomerServiceBinding {
  id           String       @id @default(cuid())
  shopId       String       @map("shop_id")
  wechatId     String       @map("wechat_id")
  qrCodeUrl    String?      @map("qr_code_url")
  status       UserStatus   @default(active)
  reviewStatus ReviewStatus @default(pending_review) @map("review_status")
  reviewedById String?      @map("reviewed_by")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId, status])
  @@map("shop_customer_service_bindings")
}

model ShopCollectionChannel {
  id               String                  @id @default(cuid())
  shopId           String                  @map("shop_id")
  channelType      CollectionChannelType   @map("channel_type")
  accountName      String                  @map("account_name")
  qrUrl            String?                 @map("qr_url")
  note             String?
  status           CollectionChannelStatus @default(pending_review)
  reviewStatus     ReviewStatus            @default(pending_review) @map("review_status")
  isDefault        Boolean                 @default(false) @map("is_default")
  reviewedById     String?                 @map("reviewed_by")
  reviewedAt       DateTime?               @map("reviewed_at")
  idempotencyKey   String                  @unique @map("idempotency_key")
  createdByAdminId String?                 @map("created_by_admin_id")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  shop                 Shop                  @relation(fields: [shopId], references: [id])
  createdBy            AdminUser?            @relation("ShopCollectionChannelCreatedBy", fields: [createdByAdminId], references: [id])
  orders               Order[]
  payments             Payment[]
  paymentConfirmations PaymentConfirmation[]

  @@index([shopId, status])
  @@index([shopId, isDefault])
  @@map("shop_collection_channels")
}

model PlatformProduct {
  id                      String          @id @default(cuid())
  productNo               String          @unique @map("product_no")
  name                    String
  categoryId              String?         @map("category_id")
  categoryName            String?         @map("category_name")
  tagsJson                Json?           @map("tags_json")
  imageUrl                String?         @map("image_url")
  specsJson               Json?           @map("specs_json")
  detailSectionsJson      Json?           @map("detail_sections_json")
  stockCount              Int             @default(0) @map("stock_count")
  soldCount               Int             @default(0) @map("sold_count")
  displayBadge            String?         @map("display_badge")
  isRecommended           Boolean         @default(false) @map("is_recommended")
  displaySort             Int             @default(0) @map("display_sort")
  detail                  String
  rightsDesc              String          @map("rights_desc")
  supplyPriceCents        BigInt          @map("supply_price_cents")
  minSalePriceCents       BigInt          @map("min_sale_price_cents")
  suggestedSalePriceCents BigInt          @map("suggested_sale_price_cents")
  fulfillmentType         FulfillmentType @default(manual) @map("fulfillment_type")
  fulfillmentRuleJson     Json            @map("fulfillment_rule_json")
  afterSaleRuleJson       Json            @map("after_sale_rule_json")
  extractCodeRequired     Boolean         @default(false) @map("extract_code_required")
  extractCodeTtlMinutes   Int?            @map("extract_code_ttl_minutes")
  status                  ProductStatus   @default(draft)
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  agentProducts          AgentProduct[]
  merchantProducts       MerchantProduct[]
  merchantProductReviews MerchantProductReview[]
  rightsCodes            RightsCode[]
  virtualCodeBatches     VirtualCodeBatch[]
  virtualCodes           VirtualCode[]
  platformShopProducts   PlatformShopProduct[]
  channelOffers          ChannelProductOffer[]
  couponScopes           CouponScope[]
  codeAccessLogs         CodePlaintextAccessLog[]

  @@index([status])
  @@map("platform_products")
}

model PlatformShopProduct {
  id                   String             @id @default(cuid())
  shopId               String             @map("shop_id")
  platformProductId    String             @map("platform_product_id")
  salePriceCents       BigInt             @map("sale_price_cents")
  fulfillmentCostCents BigInt             @default(0) @map("fulfillment_cost_cents")
  status               AgentProductStatus @default(listed)
  listedAt             DateTime?          @map("listed_at")
  delistedAt           DateTime?          @map("delisted_at")
  idempotencyKey       String?            @unique @map("idempotency_key")
  createdAt            DateTime           @default(now()) @map("created_at")
