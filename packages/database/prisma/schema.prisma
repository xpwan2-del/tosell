  reservedVirtualCodes      VirtualCode[]              @relation("VirtualCodeReservedOrder")
  extractSecrets            OrderExtractSecret[]
  couponUsages              CouponUsage[]
  clearingItems             ClearingItem[]
  refundManualConfirmations RefundManualConfirmation[]
  codeAccessLogs            CodePlaintextAccessLog[]
  channelRelation           ChannelRelation?           @relation(fields: [channelRelationId], references: [id])

