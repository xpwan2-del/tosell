{
  "buildCommand": "npm run vercel:build",
  "outputDirectory": "apps/h5/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?path=:path*"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/index.html"
    },
    {
      "source": "/s/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/user/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/merchant/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/extract",
      "destination": "/index.html"
    }
  ]
}
