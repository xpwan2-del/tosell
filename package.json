{
  "name": "tosell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:validate": "DATABASE_URL=postgresql://tosell:tosell@localhost:5432/tosell prisma validate --schema packages/database/prisma/schema.prisma",
    "db:generate": "DATABASE_URL=postgresql://tosell:tosell@localhost:5432/tosell prisma generate --schema packages/database/prisma/schema.prisma",
    "db:seed": "tsx packages/database/prisma/seed.ts",
    "db:e2e-setup": "tsx packages/database/prisma/e2e-setup.ts",
    "db:e2e-business-fixture": "tsx apps/api/src/staging-business-fixtures.ts",
    "db:business-fixtures": "tsx apps/api/src/staging-business-fixtures.ts",
    "api:smoke:production": "tsx apps/api/src/production-p0-smoke.ts",
    "test:real-db:guard": "node scripts/ensure-real-production-db.mjs",
    "db:e2e-setup:real": "npm run test:real-db:guard && npm run db:e2e-setup",
    "db:e2e-business-fixture:real": "npm run test:real-db:guard && npm run db:e2e-business-fixture",
    "api:smoke:production:real": "npm run test:real-db:guard && npm run api:smoke:production",
    "api:dev": "tsx apps/api/src/server.ts",
    "admin:dev": "vite --host 0.0.0.0 --port 5173 apps/admin",
    "vercel:build": "node scripts/build-vercel.mjs"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@prisma/client": "^6.19.0",
    "@vitejs/plugin-react": "^5.1.1",
    "fastify": "^5.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.2.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
