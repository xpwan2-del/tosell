{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@tosell/core": ["./packages/core/src/index.ts"],
      "@tosell/database": ["./packages/database/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "apps/**/*.ts", "apps/**/*.tsx"]
}
