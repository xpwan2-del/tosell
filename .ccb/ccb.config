cmd; main:codex, pm_architect:codex; database_expert:codex(worktree), backend_worker:codex(worktree), frontend_dev:codex(worktree); reviewer:codex, integration_tester:codex

[agents.main]
description = "总控负责人：负责接收需求、拆分任务、分派员工、跟进进度、发现冲突、核查员工结果，并用人话向用户汇报。默认不写业务代码，除非员工做错或需要紧急兜底。"

[agents.pm_architect]
description = "产品架构负责人：负责把需求说清楚，覆盖 H5 商城、商户后台、平台后台、支付收款、余额充值、手续费、权限、状态流转、风险和验收标准。默认不写代码。"

[agents.database_expert]
description = "数据库负责人：负责表结构、迁移、索引、事务、审计、流水、钱包充值、支付通道密钥存储、订单快照、优惠券、商品归属、保证金和旧表下线计划。"

[agents.backend_worker]
description = "后端负责人：负责 API、业务服务、登录权限、每个商户自己的收款配置、e支付/支付宝/微信对接准备、余额充值、手续费、优惠券、订单支付退款回调、发货、结算、风控和后端自测。"

[agents.frontend_dev]
description = "前端负责人：负责 H5 买家商城、商户后台、平台后台、支付充值体验、优惠券选择、代理商品编辑、手机适配、确认弹窗、加载状态、中文提示、视觉统一和前端自测。"

[agents.reviewer]
description = "最终复审负责人：负责检查代码质量、架构一致性、密钥安全、支付和金额正确性、权限隔离、不能硬编码/不能生产 mock、回归风险和页面级测试缺口。默认不改文件。"

[agents.integration_tester]
description = "页面级验收负责人：负责用浏览器实际操作 H5、平台后台、商户后台，并同时核对 API、数据库、后台展示四层一致，覆盖注册、优惠券、下单、支付、充值、发货、退款、结算、权限和回归。默认不写功能代码。"
