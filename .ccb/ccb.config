cmd; main:codex, pm_architect:codex; database_expert:codex(worktree), backend_worker:codex(worktree), frontend_dev:codex(worktree); reviewer:codex, integration_tester:codex

[agents.main]
description = "Coordinator for this B2B2C WeChat mini-program project. Owns intake, routing, sequencing, progress tracking, conflict detection, and final communication. Does not implement code by default."

[agents.pm_architect]
description = "Product and technical architecture lead. Owns requirements, admin/backend scope, business flows, status machines, permissions, risks, acceptance criteria, and task packages. Does not implement code by default."

[agents.database_expert]
description = "Database and data-integrity owner. Owns schema, migrations, indexes, transactions, audit tables, ledger design, and data consistency for agents, shops, products, orders, payments, fulfillment, refunds, settlements, deposits, and risk controls."

[agents.backend_worker]
description = "Backend implementation owner. Owns APIs, domain services, auth, order/payment/refund callbacks, fulfillment jobs, settlement logic, risk freezes, admin services, backend tests, and server-side self-checks."

[agents.frontend_dev]
description = "Frontend implementation owner. Owns mini-program user flows, agent shop/agent center UI, admin UI integration, interactions, accessibility, responsive behavior, and frontend self-checks."

[agents.reviewer]
description = "Quality and risk reviewer. Owns code quality, maintainability, architecture consistency, security risks, financial correctness risks, regression risks, and missing-test review. Does not edit files by default."

[agents.integration_tester]
description = "Integration and QA owner. Owns functional, API, UI, payment, refund, fulfillment, settlement, permission, and regression testing. Does not implement feature code by default."
